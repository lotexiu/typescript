{
  "name": "@lotexiu/typescript",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lotexiu/typescript"
  },
  "homepage": "https://github.com/lotexiu/typescript#readme",
  "bugs": {
    "url": "https://github.com/lotexiu/typescript/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "library",
    "typescript",
    "lotexiu",
    "colorjs.io"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "debug": "vitest run --inspectBrk --pool=threads --poolOptions.threads.singleThread --no-file-parallelism --testTimeout=0 --hookTimeout=0",
    "debug:watch": "vitest --inspectBrk --pool=threads --poolOptions.threads.singleThread --no-file-parallelism --testTimeout=0 --hookTimeout=0"
  },
  "devDependencies": {
    "@lotexiu/typescript-config": "workspace:*",
    "@lotexiu/vite-utils": "workspace:*",
    "@types/node": "^24.12.2",
    "@vitest/ui": "3.2.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "colorjs.io": "^0.6.1"
  },
  "sideEffects": true,
  "typings": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "type": "module",
  "types": "./dist/index.d.ts"
}
