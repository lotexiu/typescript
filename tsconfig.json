{
  "extends": "@lotexiu/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
		"types": [
			"node"
		],
		"paths": {
			"@tsn-array/*": ["./src/natives/array/*"],
      "@tsn-class/*": ["./src/natives/class/*"],
      "@tsn-console/*": ["./src/natives/console/*"],
      "@tsn-date/*": ["./src/natives/date/*"],
      "@tsn-function/*": ["./src/natives/function/*"],
      "@tsn-json/*": ["./src/natives/json/*"],
      "@tsn-math/*": ["./src/natives/math/*"],
      "@tsn-number/*": ["./src/natives/number/*"],
      "@tsn-object/*": ["./src/natives/object/*"],
      "@tsn-regex/*": ["./src/natives/regex/*"],
      "@tsn-string/*": ["./src/natives/string/*"],
      "@tsn/*": ["./src/natives/*"],
      "@tsi/*": ["./src/interfaces/*"],
      "@tsu/*": ["./src/unknown/*"],
			"@tsnode/*": ["./src/nodes/*"],
      "@ts/*": ["./src/*"]
		}
  },
  "include": ["src", "src/.test/**/*.ts", "vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
